local function tp(cf)
	if not hrp then return end
	for _ = 1, 3 do
		hrp.CFrame = cf
		RunService.Heartbeat:Wait()
	end
end

local function tpToCheckpoint(parentPath, startNum, endNum)
	for i = startNum, endNum do
		if not autoClick or not running then break end
		local cpName = "CheckpointNoSticker" .. string.format("%02d", i)
		local cpModel = parentPath:FindFirstChild(cpName)
		if cpModel then
			local touchPart = cpModel:FindFirstChild("Touch")
			if touchPart and hrp then
				tp(touchPart.CFrame)
				firetouchinterest(hrp, touchPart, 0)
				task.wait(0.1)
				firetouchinterest(hrp, touchPart, 1)
				task.wait(CP_DELAY)
			end
		end
	end
end

local function clickReplay()
	local success = false
	pcall(function()
		local replayBtn = lp.PlayerGui.PlayerUi.Popups.ObbyResults.ReplayButton
		if replayBtn and replayBtn.Visible then
			local pos = replayBtn.AbsolutePosition
			local size = replayBtn.AbsoluteSize
			VIM:SendMouseButtonEvent(pos.X + size.X/2, pos.Y + size.Y/2 + 36, 0, true, game, 0)
			task.wait(0.1)
			VIM:SendMouseButtonEvent(pos.X + size.X/2, pos.Y + size.Y/2 + 36, 0, false, game, 0)
			success = true
		end
	end)
	return success
end

