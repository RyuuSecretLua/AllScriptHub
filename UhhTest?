local function refreshToggle(noTween)
	local bgColor = toggleState and Color3.fromRGB(0, 200, 140) or Color3.fromRGB(45, 45, 60)
	local knobPos = toggleState and UDim2.new(0, 22, 0.5, -9) or UDim2.new(0, 2, 0.5, -9)
	if noTween then
		switchBtn.BackgroundColor3 = bgColor
		knob.Position = knobPos
	else
		TweenService:Create(switchBtn, TweenInfo.new(0.2), {BackgroundColor3 = bgColor}):Play()
		TweenService:Create(knob, TweenInfo.new(0.2), {Position = knobPos}):Play()
	end
end
