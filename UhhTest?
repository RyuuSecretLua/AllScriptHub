task.spawn(function()
	while running do
		task.wait(0.15)
		if not autoPickup or not hrp then continue end
		local p = workspace:FindFirstChild("Pickups")
		if p then
			for _, v in ipairs(p:GetChildren()) do
				if v:IsA("BasePart") then
					firetouchinterest(hrp, v, 0)
					firetouchinterest(hrp, v, 1)
				end
			end
		end
	end
end)

task.spawn(function()
	while running do
		if not autoClick then task.wait(1) continue end

		autoPickup = false
		tp(START_CFRAME)
		task.wait(START_DELAY)

		if not autoClick or not running then continue end

		autoPickup = true
		local LVL = workspace:WaitForChild("Level")

		tpToCheckpoint(LVL.SchoolInterior.Checkpoints, 1, 7)
		tpToCheckpoint(LVL.WallGarden.Checkpoints, 8, 12)
		tpToCheckpoint(LVL.Gymnasium.Checkpoints, 13, 21)
		tpToCheckpoint(LVL.Tower.Checkpoints, 22, 28)

		local currentTime = 0
		repeat
			task.wait(0.5)
			local parsed = tonumber((timeLabel.Text or ""):match("%d+%.?%d*"))
			currentTime = parsed or 0
		until currentTime >= TARGET_TIME or not autoClick or not running

		if not autoClick or not running then
			autoPickup = false
			continue
		end

		autoPickup = false

		local portal = workspace.Utility.Teleporters.Portal_to_Wc:FindFirstChild("Collision")
		if portal and hrp then
			hrp.CFrame = portal.CFrame
			firetouchinterest(hrp, portal, 0)
			task.wait(0.1)
			firetouchinterest(hrp, portal, 1)
		end

		local clicked = false
		local attempts = 0
		while not clicked and attempts < 40 and running and autoClick do
			clicked = clickReplay()
			task.wait(0.5)
			attempts += 1
		end

		if clicked then
			task.wait(POST_REPLAY_DELAY)
		end
	end
end)
